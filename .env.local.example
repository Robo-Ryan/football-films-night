# Copy to .env.local and fill in from Supabase dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Base URL used by the host page to build the QR code. Leave blank for auto-detect.
# Set this in Vercel to your deployed domain, e.g. https://films-night.vercel.app
NEXT_PUBLIC_SITE_URL=
